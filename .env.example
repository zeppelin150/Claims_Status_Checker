# .env.example — copy to .env and fill in real values.
# In GitHub Actions these map to repository secrets (see .github/workflows/tests.yml).

# ── Lightdash (production data source) ─────────────────────────────────────
LIGHTDASH_API_URL=
LIGHTDASH_API_KEY=
LIGHTDASH_CHART_UUID=
LIGHTDASH_PROJECT_UUID=

# ── Google Sheets ──────────────────────────────────────────────────────────
# Pick ONE auth source. Precedence: FILE > JSON > ADC.
#
#   GOOGLE_SERVICE_ACCOUNT_FILE  — path to SA JSON on disk (local dev w/ GCP access)
#   GOOGLE_SERVICE_ACCOUNT_JSON  — raw SA JSON contents (CI secrets)
#   GOOGLE_USE_ADC=true          — use gcloud user credentials (dev machine
#                                  without GCP access; run
#                                  `gcloud auth application-default login` first).
#                                  Your Google account must have at least
#                                  Editor on the target spreadsheet.
GOOGLE_SERVICE_ACCOUNT_FILE=google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_USE_ADC=
GOOGLE_SHEETS_SPREADSHEET_ID=

# ── Asana auth + project ───────────────────────────────────────────────────
ASANA_PAT=
ASANA_PROJECT_GID=
ASANA_TEST_TASK_GID=

# ── Asana GIDs (one-time discovery — run asana_seeder.py --discover to print) ──
# Sections
ASANA_SECTION_NEW=
ASANA_SECTION_WOIP=
# Custom field GIDs
ASANA_FIELD_CX_OPS=
ASANA_FIELD_CLAIMS_TEXT=
ASANA_FIELD_ALL_RETURNED=
# Custom field option GIDs
ASANA_OPT_WOIP=
ASANA_OPT_NEEDS_FOLLOWUP=
ASANA_OPT_RETURNED_YES=
ASANA_OPT_RETURNED_NO=

# ── Run recorder (legacy single-task pattern, asana_monitor.py) ────────────
# GID of the Asana task that holds run history as comments.
# Create with: python3 setup_recorder.py
ASANA_RECORDER_TASK_GID=

# ── Central log Asana project (new pattern, CXOps_BPA_*_ETL.py) ────────────
# One unified portfolio project; each automation gets its own section.
# Each pipeline run creates a fresh task in its section with the run summary.
ASANA_LOG_PROJECT_GID=
CXOPS_NORMAL_CLAIMS_ETL_LOG_SECTION_GID=

# ── Production ETL runtime mode ────────────────────────────────────────────
# IS_CI=true is ONLY honored on GitHub Actions (GITHUB_ACTIONS=true). Trying
# to set it locally raises a RuntimeError to prevent accidental production
# writes from a dev machine.
#
#   IS_CI=true                              → full production pipeline
#   IS_CI=false, WRITE_ONE_ROW=false        → dry-run, log every action
#   IS_CI=false, WRITE_ONE_ROW=true         → write first pending row only
IS_CI=false
WRITE_ONE_ROW=false

# ── Test config ────────────────────────────────────────────────────────────
TEST_CLAIM_SLUG=
